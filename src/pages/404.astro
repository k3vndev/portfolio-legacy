---
import Layout from '@/layouts/Layout.astro'
---

<Layout title='Page not Found' class='h-dvh overflow-hidden'>
  <div
    class=`
      flex flex-col items-center w-full max-w-page gap-8
      absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-3/4
    `
  >
    <h1
      class=`
        md:text-[150px] text-[100px] font-black leading-[100%]
        bg-linear-to-r from-[#674AE9] to-[#BD5BFF] bg-clip-text text-transparent
      `
    >
      404
    </h1>

    <div
      class='bg-white/5 border-white/15 border-2 rounded-xl md:px-20 px-8 py-6'
    >
      <h2
        class=`
          md:text-4xl text-2xl bg-linear-to-br from-white to-[#999] text-pretty
          font-semibold bg-clip-text text-transparent text-center
        `
      >
        Sorry, we couldn’t find the page <br class='not-md:hidden' /> you’re looking
        for :(
      </h2>
    </div>
  </div>
</Layout>
