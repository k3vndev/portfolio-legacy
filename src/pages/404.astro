---
import Layout from '@/layouts/Layout.astro'
import NotFoundScreen from '@@/NotFoundScreen.astro'
---

<Layout
  title='404 Page Not Found'
  class='h-dvh overflow-hidden'
  description='The page you are looking for does not exist. Navigate back to the portfolio home page.'
>
  <NotFoundScreen
    message="Sorry, we couldn't find the page you're looking for :("
    action={{ label: 'Go to homepage', href: '/' }}
  />
</Layout>
