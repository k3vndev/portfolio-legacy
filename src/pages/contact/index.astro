---
import Layout from '@/layouts/Layout.astro'
import { CopyText } from '@@/CopyText.tsx'
import { ContactForm } from '@@/contact-form/ContactForm'
import { EMAIL } from '@consts'
---

<Layout
  title='Contact'
  class='[&>main]:gap-16'
  description='Get in touch with Kevin Rodriguez for web development projects, collaborations, or inquiries. Contact form and email available.'
>
  <section class='margin-top-page flex gap-8 flex-col font-poppins'>
    <h1
      class='font-poppins xl:text-7xl lg:text-6xl text-5xl max-w-4xl text-white font-bold gradient-subtitle [&>strong]:text-strong-gradient animate-appear'
    >
      Let’s <strong>build</strong> something <strong>great</strong> together.
    </h1>
    <p
      class='lg:text-3xl sm:text-2xl text-xl text-zinc-300 text-pretty max-w-4xl animate-appear anim-delay-150'
    >
      Got a question or a project idea? Drop me a message here or email me
      directly at

      <CopyText
        className='text-light-gradient [&>svg]:text-[#9998fd]'
        client:idle>{EMAIL}</CopyText
      >
    </p>
  </section>

  <ContactForm client:load />
</Layout>
