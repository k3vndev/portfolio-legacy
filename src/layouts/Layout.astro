---
import AppFooter from '@@/AppFooter.astro'
import Background from '@@/Background.astro'
import AppNavigationBar from '@@/app-navigation-bar/AppNavigationBar.astro'
import { twMerge } from 'tailwind-merge'

import '../../node_modules/@k3vndev/react-carousel/dist/index.css'
import '../styles.css'

interface Props {
  title: string
  description?: string
  class?: string
  canonical?: string
  ogImage?: string
}

const {
  title,
  description = 'Fullstack Developer with 2 years building responsive, fast, and maintainable Web Applications.',
  class: className = '',
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  ogImage = new URL('/og-image.jpg', Astro.site).toString(),
} = Astro.props

// Set default title ending if not provided
export const defaultPageTitleEnding = "Kevin's Portfolio"
const hasEmDash = title.includes('—')
const siteTitle = hasEmDash ? title : `${title} — ${defaultPageTitleEnding}`
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='description' content={description} />
    <meta name='theme-color' content='#151515' />
    <meta name='robots' content='index, follow' />
    <meta name='author' content='Kevin Rodriguez' />

    <!-- Canonical URL -->
    <link rel='canonical' href={canonical} />

    <!-- Open Graph Tags -->
    <meta property='og:type' content='website' />
    <meta property='og:title' content={siteTitle} />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={ogImage} />
    <meta
      property='og:image:alt'
      content='Kevin Rodriguez - Fullstack Developer Portfolio'
    />
    <meta property='og:url' content={canonical} />
    <meta property='og:site_name' content="Kevin's Portfolio" />

    <!-- Twitter Card Tags -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={siteTitle} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImage} />

    <!-- Additional SEO -->
    <link rel='shortcut icon' href='/icon.svg' type='image/x-icon' />
    <link rel='apple-touch-icon' href='/icon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>{siteTitle}</title>

    <!-- JSON-LD Structured Data -->
    <script type='application/ld+json'>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Kevin Rodriguez",
        "url": "https://k3vn.dev",
        "image": "https://k3vn.dev/og-image.png",
        "description": "Fullstack Developer with 2 years building responsive, fast, and maintainable Web Applications",
        "jobTitle": "Fullstack Developer",
        "knowsAbout": [
          "Web Development",
          "Frontend Development",
          "Backend Development",
          "React",
          "TypeScript",
          "JavaScript"
        ],
        "sameAs": [
          "https://github.com/k3vndev",
          "https://linkedin.com/in/kevin-rodriguez"
        ]
      }
    </script>

    <script type='application/ld+json'>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Kevin Rodriguez Portfolio",
        "url": "https://k3vn.dev",
        "description": "Fullstack Developer Portfolio"
      }
    </script>
  </head>
  <body
    class={twMerge(
      `bg-[#151515] overflow-x-hidden flex justify-center ${className} min-h-dvh`,
    )}
  >
    <AppNavigationBar />

    <main class='flex flex-col md:gap-52 gap-40 max-w-page w-full'>
      <slot />
      <AppFooter />
    </main>

    <Background />
  </body>
</html>

<script>
  /*
    Scroll fade elements.
    Note: Every element should initially have 'opacity-0' class for a better effect.
  */

  const SCROLL_FADE_PROP = 'scroll-fade'
  const ANIMATION_CLASSES = ['animate-appear', 'anim-fill-both', 'opacity-100']
  const OPACITY_ZERO_CLASS = 'opacity-0'
  const MIN_INSTANT_TIME = 900

  const DELAY = { SHORT: 50, LONG: 100 }

  const elements = document.querySelectorAll(`[${SCROLL_FADE_PROP}]`)

  const handleElement = (element: HTMLElement, delayFactor: number) => {
    const delayValue = element.getAttribute(SCROLL_FADE_PROP)

    const observer = new IntersectionObserver(
      ([{ time, isIntersecting }]) => {
        if (!isIntersecting || !('style' in element)) return

        const delayTime = time < MIN_INSTANT_TIME ? DELAY.LONG : DELAY.SHORT
        element.style.animationDelay = `${delayTime * delayFactor}ms`
        console.log(`${delayTime * delayFactor}ms`)

        // Skip delays
        element.classList.remove(OPACITY_ZERO_CLASS)
        element.classList.add(...ANIMATION_CLASSES)

        observer.disconnect()
      },
      { rootMargin: '50px' },
    )
    observer.observe(element)
  }

  for (const element of elements) {
    // Get delay factor
    const delayFactor = element.getAttribute(SCROLL_FADE_PROP)
    if (!delayFactor || Number.isNaN(+delayFactor - 1)) {
      console.error('Invalid value given at', element)
      break
    }

    handleElement(element as HTMLElement, +delayFactor)
  }
</script>
