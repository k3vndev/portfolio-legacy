---
import { SOCIALS } from '@consts'
import LinkButton from './LinkButton.astro'
---

<div class='flex flex-wrap gap-2 md:gap-3 mt-7 md:mt-4'>
  {
    SOCIALS.map(({ label, link, icon: Icon }, i) => (
      <LinkButton
        ariaLabel={label}
        href={link}
        class='gap-2 sm:px-6 px-5 py-1.5 rounded-full'
      >
        <Icon className='size-6' />
        <span class={`text-xl font-semibold ${i ? 'hidden md:block' : ''}`}>
          {label}
        </span>
      </LinkButton>
    ))
  }
</div>
