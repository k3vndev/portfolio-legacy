---
import type { Tecnology } from '@types'
import { twMerge } from 'tailwind-merge'
import TechnologyBadge from './TechnologyBadge.astro'

interface Props {
  technologies: Tecnology[]
  class?: string
}

const { technologies, class: className } = Astro.props as Props
---

<ul class={twMerge(`flex gap-1 flex-nowrap items-center ${className}`)}>
  {technologies.map((tech) => <TechnologyBadge {...tech} />)}
</ul>
