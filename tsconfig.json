{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",

    "paths": {
      "@@/*": ["src/components/*"],
      "@icons": ["src/components/icons.tsx"],
      "@types": ["src/types.d.ts"],
      "@consts": ["src/consts.ts"],
      "@utils": ["src/utils/index.ts"],
      "@/*": ["src/*"]
    }
  }
}
